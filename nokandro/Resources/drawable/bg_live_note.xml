<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="rectangle">
      <solid android:color="@color/surface" />
      <stroke android:width="1dp" android:color="@color/outline" />
      <corners android:radius="@dimen/corner_md" />
    </shape>
  </item>
  <item android:gravity="start" android:left="1dp" android:top="1dp" android:bottom="1dp">
    <shape android:shape="rectangle">
      <solid android:color="@color/primary" />
      <size android:width="4dp" />
      <corners 
        android:topLeftRadius="@dimen/corner_md"
        android:bottomLeftRadius="@dimen/corner_md"
        android:topRightRadius="0dp"
        android:bottomRightRadius="0dp" />
    </shape>
  </item>
</layer-list>
