<?xml version="1.0" encoding="utf-8"?>
<resources>
  <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
    <item name="colorPrimary">@color/primary</item>
    <item name="colorPrimaryDark">@color/primary_dark</item>
    <item name="colorAccent">@color/primary_light</item>
    <item name="colorOnPrimary">@color/on_primary</item>
    <item name="colorPrimaryContainer">@color/primary_container</item>
    <item name="colorOnPrimaryContainer">@color/primary</item>
    <item name="colorSurface">@color/surface</item>
    <item name="colorOnSurface">@color/on_surface</item>
    <item name="colorOutline">@color/outline</item>
    <item name="android:windowBackground">@color/background</item>
    <item name="android:colorBackground">@color/background</item>
    <item name="android:statusBarColor">@color/primary_dark</item>
    <item name="android:fontFamily">sans-serif</item>
    <item name="android:textViewStyle">@style/AppTextView</item>
    <item name="android:editTextStyle">@style/AppEditText</item>
    <item name="materialButtonStyle">@style/AppButtonPrimary</item>
    <item name="tabStyle">@style/AppTabLayout</item>
  </style>

  <style name="AppTheme.Dialog" parent="Theme.Material3.Light.Dialog">
    <item name="colorPrimary">@color/primary</item>
    <item name="colorOnPrimary">@color/on_primary</item>
    <item name="colorSurface">@color/surface</item>
    <item name="colorOnSurface">@color/on_surface</item>
  </style>

  <style name="AppTheme.QuickPostDialog" parent="AppTheme.Dialog">
    <item name="android:windowMinWidthMajor">90%</item>
    <item name="android:windowMinWidthMinor">90%</item>
  </style>

  <style name="AppTextView">
    <item name="android:fontFamily">sans-serif</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textStyle">normal</item>
    <item name="android:textColor">@color/on_surface</item>
  </style>

  <style name="AppEditText" parent="Widget.AppCompat.EditText">
    <item name="android:fontFamily">sans-serif</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textColor">@color/on_surface</item>
    <item name="android:textColorHint">@color/on_surface_variant</item>
  </style>

  <style name="AppButtonPrimary" parent="Widget.Material3.Button">
    <item name="android:fontFamily">sans-serif-medium</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textAllCaps">false</item>
    <item name="backgroundTint">@color/primary</item>
    <item name="android:textColor">@color/on_primary</item>
    <item name="cornerRadius">@dimen/corner_sm</item>
    <item name="android:minHeight">@dimen/row_min_height</item>
  </style>

  <style name="AppButtonOutlined" parent="Widget.Material3.Button.OutlinedButton">
    <item name="android:fontFamily">sans-serif-medium</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textAllCaps">false</item>
    <item name="strokeColor">@color/outline</item>
    <item name="android:textColor">@color/on_surface</item>
    <item name="cornerRadius">@dimen/corner_sm</item>
    <item name="android:minHeight">@dimen/row_min_height</item>
  </style>

  <style name="AppButtonText" parent="Widget.Material3.Button.TextButton">
    <item name="android:fontFamily">sans-serif-medium</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textAllCaps">false</item>
    <item name="android:textColor">@color/primary</item>
    <item name="android:minHeight">@dimen/row_min_height</item>
  </style>

  <style name="AppButtonSecondary" parent="Widget.Material3.Button.OutlinedButton">
    <item name="android:fontFamily">sans-serif-medium</item>
    <item name="android:textSize">13sp</item>
    <item name="android:textAllCaps">false</item>
    <item name="strokeColor">@color/outline</item>
    <item name="android:textColor">@color/on_surface</item>
    <item name="cornerRadius">@dimen/corner_sm</item>
    <item name="android:minHeight">36dp</item>
  </style>

  <style name="SectionCard">
    <item name="android:background">@drawable/bg_section_card</item>
    <item name="android:padding">@dimen/spacing_lg</item>
  </style>

  <style name="SectionTitle">
    <item name="android:fontFamily">sans-serif-medium</item>
    <item name="android:textSize">15sp</item>
    <item name="android:textColor">@color/on_surface</item>
  </style>

  <style name="SectionHeaderLabel">
    <item name="android:fontFamily">sans-serif-medium</item>
    <item name="android:textSize">@dimen/section_header_text</item>
    <item name="android:textColor">@color/on_surface_variant</item>
    <item name="android:textAllCaps">true</item>
    <item name="android:letterSpacing">0.05</item>
    <item name="android:paddingStart">@dimen/spacing_xs</item>
    <item name="android:paddingEnd">@dimen/spacing_xs</item>
    <item name="android:paddingTop">@dimen/spacing_md</item>
    <item name="android:paddingBottom">@dimen/spacing_xs</item>
  </style>

  <style name="HintText">
    <item name="android:textSize">12sp</item>
    <item name="android:textColor">@color/on_surface_variant</item>
  </style>

  <style name="LiveNoteCard">
    <item name="android:background">@drawable/bg_live_note</item>
    <item name="android:padding">@dimen/spacing_lg</item>
    <item name="android:textColor">@color/on_surface</item>
    <item name="android:textSize">14sp</item>
    <item name="android:lineSpacingMultiplier">1.2</item>
  </style>

  <style name="AppTabLayout" parent="Widget.Material3.TabLayout">
    <item name="tabIndicatorColor">@color/primary</item>
    <item name="tabSelectedTextColor">@color/primary</item>
    <item name="tabTextColor">@color/on_surface_variant</item>
    <item name="tabIndicatorFullWidth">true</item>
    <item name="tabMode">fixed</item>
  </style>

  <style name="AppTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
    <item name="boxStrokeColor">@color/primary</item>
    <item name="hintTextColor">@color/on_surface_variant</item>
    <item name="boxCornerRadiusTopStart">12dp</item>
    <item name="boxCornerRadiusTopEnd">12dp</item>
    <item name="boxCornerRadiusBottomStart">12dp</item>
    <item name="boxCornerRadiusBottomEnd">12dp</item>
    <item name="boxStrokeWidth">1dp</item>
    <item name="boxStrokeWidthFocused">2dp</item>
  </style>

  <style name="StatusChipText">
    <item name="android:background">@drawable/bg_status_chip</item>
    <item name="android:paddingStart">12dp</item>
    <item name="android:paddingEnd">12dp</item>
    <item name="android:paddingTop">6dp</item>
    <item name="android:paddingBottom">6dp</item>
    <item name="android:textColor">@color/primary</item>
    <item name="android:textSize">11sp</item>
    <item name="android:textStyle">bold</item>
    <item name="android:gravity">center</item>
  </style>

  <style name="NowPlayingBar">
    <item name="android:background">@drawable/bg_now_playing</item>
    <item name="android:padding">12dp</item>
    <item name="android:textColor">@color/on_surface</item>
    <item name="android:textSize">13sp</item>
    <item name="android:lineSpacingMultiplier">1.1</item>
  </style>

  <style name="CodeBoxText">
    <item name="android:background">@drawable/bg_code_box</item>
    <item name="android:padding">12dp</item>
    <item name="android:textColor">@color/on_surface</item>
    <item name="android:textSize">12sp</item>
    <item name="android:fontFamily">monospace</item>
  </style>
</resources>
