<?xml version="1.0" encoding="utf-8"?>
<resources>
  <style name="AppTheme" parent="@android:style/Theme.Material.Light.DarkActionBar">
    <item name="android:fontFamily">sans-serif</item>
    <item name="android:windowBackground">#FDF2F8</item>
    <item name="android:colorBackground">#FDF2F8</item>
    <item name="android:colorPrimary">#FF4081</item>
    <item name="android:colorPrimaryDark">#C2185B</item>
    <item name="android:colorAccent">#E91E63</item>
    <item name="android:textViewStyle">@style/AppTextView</item>
    <item name="android:editTextStyle">@style/AppEditText</item>
    <item name="android:buttonStyle">@style/AppButton</item>
  </style>

  <style name="AppTextView">
    <item name="android:fontFamily">sans-serif</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textStyle">normal</item>
    <item name="android:textColor">#1F2937</item>
  </style>

  <style name="AppEditText" parent="@android:style/Widget.Material.EditText">
    <item name="android:fontFamily">sans-serif</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textStyle">normal</item>
    <item name="android:textColor">#111827</item>
    <item name="android:textColorHint">#6B7280</item>
  </style>

  <style name="AppButton" parent="@android:style/Widget.Material.Button">
    <item name="android:fontFamily">sans-serif-medium</item>
    <item name="android:textSize">14sp</item>
    <item name="android:textStyle">normal</item>
    <item name="android:textAllCaps">false</item>
    <item name="android:minHeight">40dp</item>
    <item name="android:paddingStart">14dp</item>
    <item name="android:paddingEnd">14dp</item>
  </style>

  <style name="SectionCard">
    <item name="android:background">@drawable/panel_card</item>
    <item name="android:padding">14dp</item>
  </style>

  <style name="SectionTitle">
    <item name="android:fontFamily">sans-serif-medium</item>
    <item name="android:textSize">15sp</item>
    <item name="android:textColor">#111827</item>
  </style>
</resources>
